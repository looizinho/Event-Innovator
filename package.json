{
  "name": "workspace",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "preinstall": "true",
    "dev": "pnpm run dev:api & pnpm run dev:web & wait",
    "dev:api": "PORT=${API_PORT:-4101} pnpm --dir artifacts/api-server run dev",
    "dev:web": "API_PROXY_TARGET=${API_PROXY_TARGET:-http://127.0.0.1:${API_PORT:-4101}} PORT=${PORT:-4100} pnpm --dir artifacts/portfolio run dev",
    "build": "pnpm run typecheck && pnpm -r --if-present run build",
    "typecheck:libs": "tsc --build",
    "typecheck": "pnpm run typecheck:libs && pnpm -r --filter \"./artifacts/**\" --filter \"./scripts\" --if-present run typecheck"
  },
  "private": true,
  "devDependencies": {
    "prettier": "^3.8.3",
    "typescript": "~5.9.3"
  },
  "dependencies": {
    "@esbuild/darwin-arm64": "0.27.3",
    "@rollup/rollup-darwin-arm64": "4.60.3",
    "@tailwindcss/oxide-darwin-arm64": "4.3.0",
    "lightningcss-darwin-arm64": "1.32.0"
  }
}
